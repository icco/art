# Server
PORT=8080
DATABASE_URL=postgres://art:art@localhost:5432/art?sslmode=disable
LOG_LEVEL=info
ART_TIMEZONE=America/Los_Angeles

# OIDC: the audience used to mint and validate inbound ID tokens.
# The TUI passes this same value via `gcloud auth print-identity-token --audiences=...`.
OIDC_AUDIENCE=https://art.example.com
OWNER_EMAILS=you@example.com,you@work-example.com

# OAuth client credentials for the per-account user flow (NOT the Vertex service account).
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/oauth/callback

# Vertex AI (used when the LLM-orchestrated planner mode is wired up; v1 deterministic planner
# does not call Vertex). VERTEX_SA_PATH is what docker-compose mounts at /secrets/vertex-sa.json.
VERTEX_SA_PATH=./vertex-sa.json
GOOGLE_APPLICATION_CREDENTIALS=/secrets/vertex-sa.json
VERTEX_PROJECT_ID=your-gcp-project
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-pro

# AES-256 key for refresh-token encryption at rest. Generate with:
#   openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=replace-me-with-32-bytes-base64
