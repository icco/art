# Server
PORT=8080
DATABASE_URL=postgres://art:art@localhost:5432/art?sslmode=disable
ART_TIMEZONE=America/Los_Angeles

# OIDC — the TUI passes OIDC_AUDIENCE to `gcloud auth print-identity-token`.
OIDC_AUDIENCE=https://art.example.com
OWNER_EMAILS=you@example.com,you@work-example.com

# Per-client-IP request rate limit (requests/minute). Keyed on the real client
# IP (rightmost X-Forwarded-For hop behind the trusted proxy). Default 120.
RATE_LIMIT_RPM=120

# OAuth client for the per-account user consent flow.
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/oauth/callback

# Vertex (unused until the LLM planner lands).
VERTEX_SA_PATH=./vertex-sa.json
GOOGLE_APPLICATION_CREDENTIALS=/secrets/vertex-sa.json
VERTEX_PROJECT_ID=your-gcp-project
VERTEX_LOCATION=us-central1

# AES-256 key for refresh-token encryption. Generate: `openssl rand -base64 32`.
TOKEN_ENCRYPTION_KEY=replace-me-with-32-bytes-base64

# Email triage (Gmail). Requires the gmail.modify scope — re-link both accounts
# after enabling. Set TRIAGE_DRY_RUN=true for the first run to inspect decisions
# without changing Gmail.
TRIAGE_ENABLED=true
TRIAGE_DRY_RUN=false
TRIAGE_BACKFILL_DAYS=14
TRIAGE_MAX_PER_RUN=50
TRIAGE_CONFIDENCE_THRESHOLD=0.8
TRIAGE_RECONCILE_DAYS=14
